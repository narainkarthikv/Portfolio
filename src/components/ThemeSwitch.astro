---
import { Icon } from 'astro-icon/components'
---

<div class="inline-flex items-center gap-3 print:hidden">
  <!-- Dark Mode Toggle -->
  <button
    id="themeSwitch"
    aria-label="Toggle dark mode"
    aria-pressed="false"
    class="group rounded-xl p-2 flex items-center transition-all duration-300 hover:bg-skin-muted/20 active:scale-95"
  >
    <Icon
      name="ri:moon-fill"
      width={28}
      height={28}
      class="hidden dark:block transition-colors duration-300"
    />
    <Icon
      name="ri:sun-fill"
      width={28}
      height={28}
      class="dark:hidden transition-colors duration-300"
    />
  </button>

  <!-- Theme Select Menu -->
  <select
    id="themeSelect"
    class="rounded-lg border border-skin-muted bg-transparent px-3 py-1.5 text-sm text-skin-base focus:ring-2 focus:ring-skin-hue"
  >
    <option value="blue">Blue</option>
    <option value="green">Green</option>
    <option value="luffy">Luffy</option>
    <option value="orange">Orange</option>
    <option value="red">Red</option>
  </select>
</div>

<style>
  :global(.dark) {
    color-scheme: dark;
  }
</style>

<script>
  let isDark = document.documentElement.classList.contains("dark")

  /** ————————————————————————————
   *  Toggle Dark Mode with Smooth Transition
   * ———————————————————————————— */
  function toggleDark(e) {
    const animationSupported =
      "startViewTransition" in document &&
      !window.matchMedia("(prefers-reduced-motion: reduce)").matches

    if (!animationSupported) {
      isDark = !isDark
      applyDark()
      return
    }

    const x = e.clientX
    const y = e.clientY
    const endRadius = Math.hypot(
      Math.max(x, innerWidth - x),
      Math.max(y, innerHeight - y)
    )

    // @ts-ignore
    const transition = document.startViewTransition(() => {
      isDark = !isDark
      applyDark()
    })

    transition.ready.then(() => {
      const from = `circle(0px at ${x}px ${y}px)`
      const to = `circle(${endRadius}px at ${x}px ${y}px)`

      document.documentElement.animate(
        { clipPath: isDark ? [to, from] : [from, to] },
        {
          duration: 450,
          easing: "ease-out",
          pseudoElement: isDark
            ? "::view-transition-old(root)"
            : "::view-transition-new(root)",
        }
      )
    })
  }

  function applyDark() {
    document.documentElement.classList.toggle("dark", isDark)
    document
      .getElementById("themeSwitch")
      .setAttribute("aria-pressed", String(isDark))
    localStorage.setItem("theme", isDark ? "dark" : "light")
  }

  /** ————————————————————————————
   *  Color Theme Selection
   * ———————————————————————————— */
  function applyColorTheme(value) {
    document.body.dataset.theme = value
    localStorage.setItem("data-theme", value)
  }

  const switchBtn = document.getElementById("themeSwitch")
  switchBtn?.addEventListener("click", toggleDark)

  const themeSelect = document.getElementById("themeSelect")
  themeSelect?.addEventListener("change", e => {
    applyColorTheme(e.target.value)
  })

  /** ————————————————————————————
   *  Initialization
   * ———————————————————————————— */

  // Dark mode initialization
  const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches
  const storedTheme = localStorage.theme

  isDark = storedTheme === "dark" || (!storedTheme && systemDark)
  applyDark()

  // Color theme initialization
  const savedColor = localStorage.getItem("data-theme") || "blue"
  applyColorTheme(savedColor)
  if (themeSelect) themeSelect.value = savedColor

  // Listen to system changes
  window
    .matchMedia("(prefers-color-scheme: dark)")
    .addEventListener("change", e => {
      if (!localStorage.theme) {
        isDark = e.matches
        applyDark()
      }
    })
</script>

<style is:global>
  ::view-transition-old(root),
  ::view-transition-new(root) {
    animation: none;
    mix-blend-mode: normal;
  }

  ::view-transition-new(root) {
    z-index: 9999;
  }
  .dark ::view-transition-new(root) {
    z-index: 1;
  }
</style>
